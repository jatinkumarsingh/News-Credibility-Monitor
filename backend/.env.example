# Copy to .env (next to this file) and fill in real keys.
# Render: set these in the service's Environment tab instead of committing them.

GROQ_API_KEY=gsk_your_groq_key_here
NVIDIA_API_KEY=nvapi-your_nvidia_key_here

# Comma-separated list of origins allowed to call the API (no trailing slashes).
# Example: https://news-credibility-monitor.vercel.app,http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional regex for Vercel preview URLs, e.g.
# ^https:\/\/news-credibility-monitor-.*-your-team\.vercel\.app$
CORS_ALLOW_ORIGIN_REGEX=
